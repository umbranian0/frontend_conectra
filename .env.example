# For Docker frontend -> host Strapi (recommended default)
VITE_STRAPI_URL=http://host.docker.internal:1337

# If running frontend outside Docker, use: http://localhost:1337
VITE_STRAPI_AUTH_ENDPOINT=/api/auth/local
VITE_STRAPI_USERS_ENDPOINT=/api/users
VITE_STRAPI_ACTIVITIES_ENDPOINT=/api/activities

# Optional: local published frontend port when using Docker Compose
FRONTEND_PORT=5173