{
  "name": "connecttroca-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Strapi-connected frontend prototype for login, users and activities pages",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "build": "node --max-old-space-size=256 ./node_modules/vite/bin/vite.js build --minify=false",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f frontend",
    "docker:rebuild": "docker compose build --no-cache"
  },
  "keywords": [
    "react",
    "vite",
    "strapi",
    "frontend",
    "prototype"
  ],
  
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.7.0",
    "vite": "^5.4.21"
  }
}